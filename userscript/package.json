{
  "name": "manga-image-translator-userscript",
  "private": true,
  "version": "1.2.10",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "pnpm typecheck && pnpm test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "release:patch": "pnpm version patch --no-git-tag-version && pnpm build",
    "release:minor": "pnpm version minor --no-git-tag-version && pnpm build",
    "release:major": "pnpm version major --no-git-tag-version && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.4",
    "vite-plugin-monkey": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
